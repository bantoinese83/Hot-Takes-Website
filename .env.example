# Copy to .env.local and fill with your Hot Take Supabase project (same as the iOS app).
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Admin dashboard (/admin) uses the same keys + Supabase Auth (allowlisted email in website_admins).

# Waitlist: register_launch_waitlist + get_launch_waitlist_progress (migrations 20260528*, 20260529120000_*).
# Set launch goal in Supabase: UPDATE app_launch_settings SET waitlist_goal = 500 WHERE id = 1;
# Optional display fallback if RPC unavailable:
# VITE_WAITLIST_GOAL=500

# Intel (/admin/intel): local = Ollama via dev proxy; production = Gemini (Supabase admin-intel).
# VITE_OLLAMA_BASE_URL=/ollama
# Gemini: set GEMINI_API_KEY + deploy admin-intel (see docs/ADMIN_INTEL.md)
